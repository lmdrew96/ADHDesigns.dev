# Resend API key — used by /api/services-inquiry to send tier inquiry emails
# Get a key at https://resend.com/api-keys
RESEND_API_KEY=

# Where service inquiry emails are sent. Defaults to nae@adhdesigns.dev if unset.
SERVICES_INQUIRY_TO=nae@adhdesigns.dev

# Verified sender domain on Resend (e.g. "ADHDesigns <noreply@adhdesigns.dev>").
# Until your domain is verified, you can use "onboarding@resend.dev" for testing.
SERVICES_INQUIRY_FROM=ADHDesigns <noreply@adhdesigns.dev>
